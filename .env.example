# ── SatNOGS Offline Pipeline ──
SATNOGS_API_TOKEN=your_token_here

# ── Docker Compose Services ──
POSTGRES_USER=watchdog
POSTGRES_PASSWORD=watchdog_pass
POSTGRES_DB=watchdog_db

# Frontend: change this to your server's address for remote deployments
PUBLIC_API_URL=http://localhost:8000
PUBLIC_WS_URL=ws://localhost:8000/ws

# ── Cloud VPS Infrastructure ──
MQTT_ALLOW_ANONYMOUS=false
MQTT_USER=edge_station_1
MQTT_PASSWORD=your_secure_password

# ── Edge Agent (Ground Station) ──
CLOUD_MQTT_HOST=vps.yourdomain.com
CLOUD_MQTT_PORT=1883
EDGE_LOCAL_BACKUP_PATH=./data/backups/live_pass_buffer.csv
EDGE_RETRY_INTERVAL_SECONDS=5
